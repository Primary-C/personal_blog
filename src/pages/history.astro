---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const currentPosts = await getCollection('blog');
const allPosts = currentPosts.map(post => ({
	id: post.id,
	title: post.data.title,
	description: post.data.description,
	pubDate: post.data.pubDate.toISOString(),
	tags: post.data.tags || []
}));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`History | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.cal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2em; }
			.cal-header button { background: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-color); padding: 0.5em 1.5em; border-radius: var(--radius); cursor: pointer; font-family: var(--font-mono); transition: all 0.2s; }
			.cal-header button:hover { border-color: var(--accent); color: var(--accent); }
			
			.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.5em; text-align: center; margin-bottom: 3em;}
			.cal-day-header { font-weight: bold; padding: 0.5em; color: var(--text-muted); font-family: var(--font-mono); }
			.cal-cell { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 1.5em 0.5em; cursor: pointer; position: relative; transition: all 0.2s; }
			.cal-cell.empty { background: transparent; border: none; cursor: default; }
			
			.cal-cell:hover:not(.empty) { border-color: var(--accent); transform: translateY(-2px); }
			.cal-cell.selected { border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent) inset; }
			
			/* Dot indicating a post */
			.cal-cell.has-post .post-dot {
				width: 8px; height: 8px; background-color: var(--accent); border-radius: 50%; 
				position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%);
			}
			
			.selected-date-title { margin-top: 2em; margin-bottom: 1em; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5em; font-family: var(--font-mono); color: var(--accent); }
			.post-list { display: flex; flex-direction: column; gap: 1rem; }
			em {color: var(--accent); font-style: normal;}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="cal-header">
				<button id="prev-btn">&lt; Prev</button>
				<h2 id="month-label" style="margin:0;">2026. 04</h2>
				<button id="next-btn">Next &gt;</button>
			</div>
			
			<div class="cal-grid" id="cal-grid">
				<!-- Calendar UI injected by Vanilla JS -->
			</div>

			<h3 class="selected-date-title" id="selected-date-title">기록 보관소 대기 중</h3>
			<section class="post-list" id="post-list">
				<p style="color: var(--text-muted); text-align: center; padding: 2em;">상단 달력에서 <em>포스팅 마커(라벤더색 점)</em>가 표시된 날짜를 클릭하십시오.</p>
			</section>
		</main>
		<Footer />

		<script define:vars={{ allPosts }}>
			const posts = allPosts;
			let currentDate = new Date(); // local current date
			
			const monthLabel = document.getElementById('month-label');
			const calGrid = document.getElementById('cal-grid');
			const postList = document.getElementById('post-list');
			const selectedDateTitle = document.getElementById('selected-date-title');
			
			const daysOfWeek = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

			function renderCalendar(date) {
				const year = date.getFullYear();
				const month = date.getMonth();
				
				monthLabel.textContent = `${year}. ${String(month + 1).padStart(2, '0')}`;
				
				const firstDay = new Date(year, month, 1).getDay(); // 0 is Sunday
				const daysInMonth = new Date(year, month + 1, 0).getDate();
				
				let html = '';
				daysOfWeek.forEach(day => {
					html += `<div class="cal-day-header">${day}</div>`;
				});
				
				// fill empty cells for first week
				for(let i = 0; i < firstDay; i++) {
					html += `<div class="cal-cell empty"></div>`;
				}
				
				// actual day cells
				for(let day = 1; day <= daysInMonth; day++) {
					const postsOnDay = posts.filter(p => {
						const d = new Date(p.pubDate);
						return d.getFullYear() === year && d.getMonth() === month && d.getDate() === day;
					});
					
					const dotHtml = postsOnDay.length > 0 ? `<div class="post-dot"></div>` : '';
					const hasPostClass = postsOnDay.length > 0 ? 'has-post' : '';
					
					html += `<div class="cal-cell ${hasPostClass}" data-year="${year}" data-month="${month}" data-day="${day}">
								<span style="font-weight: ${postsOnDay.length > 0 ? 'bold' : 'normal'}; color: ${postsOnDay.length > 0 ? '#fff' : 'inherit'};">${day}</span>
								${dotHtml}
							</div>`;
				}
				
				calGrid.innerHTML = html;
				
				document.querySelectorAll('.cal-cell').forEach(cell => {
					if(cell.classList.contains('empty')) return;
					cell.addEventListener('click', (e) => {
						document.querySelectorAll('.cal-cell').forEach(c => c.classList.remove('selected'));
						e.currentTarget.classList.add('selected');
						
						const y = parseInt(cell.getAttribute('data-year'));
						const m = parseInt(cell.getAttribute('data-month'));
						const d = parseInt(cell.getAttribute('data-day'));
						
						renderPostsForDate(new Date(y, m, d));
					});
				});
			}

			function renderPostsForDate(date) {
				const y = date.getFullYear();
				const m = date.getMonth();
				const d = date.getDate();
				
				selectedDateTitle.textContent = `${y}. ${String(m + 1).padStart(2, '0')}. ${String(d).padStart(2, '0')} 아카이브`;
				
				const matchingPosts = posts.filter(p => {
					const postDate = new Date(p.pubDate);
					return postDate.getFullYear() === y && postDate.getMonth() === m && postDate.getDate() === d;
				});
				
				if(matchingPosts.length === 0) {
					postList.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 2em;">이 접속일에는 작성된 데이터가 없습니다.</p>';
					return;
				}
				
				let listHtml = '';
				matchingPosts.forEach(post => {
					let tagsHtml = post.tags && post.tags.length > 0 
						? post.tags.map(tag => `<span class="badge">#${tag}</span>`).join('') 
						: `<span class="badge">Tech_Archive</span>`;
						
					const pd = new Date(post.pubDate);
					const dateStr = pd.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' });

					listHtml += `<a href="/blog/${post.id}/" class="card post-card" style="display:block; text-decoration:none;">
									${tagsHtml}
									<h3 class="title" style="margin-top:0.5em; color: #fff;">${post.title}</h3>
									<span class="date" style="font-size:0.85em; color:var(--text-muted); display:block; margin-bottom:0.8em; font-family:var(--font-mono);">
										<time datetime="${post.pubDate}">${dateStr}</time>
									</span>
									<p style="margin-bottom:0; color:var(--text-muted);">${post.description}</p>
								</a>`;
				});
				
				postList.innerHTML = listHtml;
			}

			document.getElementById('prev-btn').addEventListener('click', () => {
				currentDate.setMonth(currentDate.getMonth() - 1);
				renderCalendar(currentDate);
			});

			document.getElementById('next-btn').addEventListener('click', () => {
				currentDate.setMonth(currentDate.getMonth() + 1);
				renderCalendar(currentDate);
			});

			// 초기 실행 (로딩 시 달력만 띄워두고 하단은 안내문)
			renderCalendar(currentDate);
			
			// 오늘 날짜에 글이 등록된 경우 편의를 위해 오늘 날짜를 클릭한 상태로 시작. 
			// 하지만 기본적으로는 접속자가 직접 마커를 누르게 렌더링 유지.
		</script>
	</body>
</html>
